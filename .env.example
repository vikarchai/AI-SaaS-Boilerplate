# Copy to .env and fill in. Only variables listed here are read by config/env.ts (the server).

# --- Postgres (local: docker compose -f docker/docker-compose.yml uses host port 5433)
DATABASE_URL=postgres://app:app@localhost:5433/app

# --- Server
# PORT=3000
# SERVE_CLIENT=false   # production API-only behind nginx / split Docker stack

# --- Better Auth (required for sign-in when DATABASE_URL is set)
BETTER_AUTH_SECRET=replace-with-long-random-string-min-16-chars
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth (optional; magic link works without)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # Signing secret from Dashboard or `stripe listen`, NOT the webhook URL
# STRIPE_PLAN_METADATA_KEY=product   # optional; which Product metadata marks a plan
# STRIPE_PLAN_METADATA_VALUE=plan

# --- LLM (optional; at least one of the two for /api/chat)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Note: Plans and price IDs on /billing come from Stripe (products with metadata above +
# active recurring prices). Extra keys like STRIPE_PRICE_* are not used by this app.
